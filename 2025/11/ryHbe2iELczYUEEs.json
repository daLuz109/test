      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT outerParents.UserId                              as AppUserId,\n       (SELECT innerUsers.UserId\n        FROM VanEscola.dbo.Users innerUsers\n                 JOIN VanEscola.dbo.Parents innerParents\n                      ON innerUsers.UserId = innerParents.UserId AND innerUsers.PhoneNumber = innerParents.PhoneNumber\n        WHERE innerUsers.PhoneNumber = outerParents.PhoneNumber\n          AND innerUsers.UserId <> outerParents.UserId) as CreatedUserId\nFROM VanEscola.dbo.Parents outerParents\n         JOIN VanEscola.dbo.Users ON outerParents.UserId = Users.UserId\n    AND Users.PhoneNumber IS NULL\nWHERE (SELECT COUNT(*)\n       FROM VanEscola.dbo.Users\n                JOIN VanEscola.dbo.Parents ON Users.UserId = Parents.UserId AND Users.PhoneNumber = Parents.PhoneNumber\n       WHERE Users.PhoneNumber = outerParents.PhoneNumber\n         AND Users.UserId <> outerParents.UserId) = 1"
      },
