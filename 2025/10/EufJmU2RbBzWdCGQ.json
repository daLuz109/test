        "parameters": {
          "jsCode": "const raw = $input.first().json.error.message;\n\n// remove \"400 - \"\nconst clean = raw.replace(/^\\d+\\s*-\\s*/, '');\n\n// 1º parse (vira string JSON)\nconst firstParse = JSON.parse(clean);\n\n// 2º parse (vira objeto real)\nconst errorObj = JSON.parse(firstParse);\n\nreturn [{\n  errorObj: errorObj\n}];"
