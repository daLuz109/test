          "jsCode": "const input = $json;\n\n// pega mensagem independente do formato\nconst raw =\n  input?.raw ||\n  input?.message ||\n  input?.error ||\n  JSON.stringify(input);\n\n// normaliza pra string\nconst text = typeof raw === 'string' ? raw : JSON.stringify(raw);\n\n// flags padrão\nlet isPhoneInvalid = false;\nlet isLinkInvalid = false;\n\n// ---------------------------\n// PHONE INVALID\n// ---------------------------\nif (text.includes('\"exists\":false') || text.includes('Bad request - please check your parameters')) {\n  isPhoneInvalid = true;\n}\n\n// ---------------------------\n// LINK INVALID\n// ---------------------------\nif (text.includes('AxiosError: Request failed with status code 403')) {\n  isLinkInvalid = true;\n}\n\n// retorno padronizado\nreturn [\n  {\n    isPhoneInvalid,\n    isLinkInvalid,\n    raw: input\n  }\n];"
